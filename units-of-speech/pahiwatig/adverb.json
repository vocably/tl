{"transcript":"pa.hi.wa.ˈtiɡ","exists":true,"definitions":["Sa paraang nagbibigay ng hudyat o hindi tuwirang mensahe.","Paikut-ikot o hindi direktang pagpapahayag."],"examples":["Pahiwatig siyang sumagot.","Nagsalita siya nang pahiwatig."],"lemma":"hiwatig","lemmaPos":"noun","synonyms":["pasaring","patama","pauyam"],"number":"singular","source":"pahiwatig"}